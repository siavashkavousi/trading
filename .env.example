# Nobitex exchange credentials
# Obtain from Nobitex account panel or via /auth/login/ endpoint
NOBITEX_API_TOKEN=

# KCEX exchange credentials (KuCoin-style API key authentication)
KCEX_API_KEY=
KCEX_API_SECRET=
KCEX_API_PASSPHRASE=

# PostgreSQL cold store (optional, omit to run without persistent cold storage)
POSTGRES_PASSWORD=

# Grafana dashboard password (used by docker-compose)
GRAFANA_PASSWORD=admin
